generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  DELETED
}

enum ProficiencyLevel {
  BEGINNER
  ELEMENTARY
  INTERMEDIATE
  UPPER_INTERMEDIATE
  ADVANCED
  MASTERY
}

enum PostStatus {
  DRAFT
  PUBLISHED
  HIDDEN
  FLAGGED
  ACCEPTED
  DELETED
}

enum PostVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum PostCompleteness {
  COMPLETE
  PARTIAL
  IDEA_ONLY
}

enum CorrectionStatus {
  DRAFT
  PUBLISHED
  HIDDEN
  DELETED
}

enum NotificationType {
  CORRECTION_RECEIVED
  CORRECTION_ADOPTED
  REPUTATION_GAINED
  POST_FLAGGED
  POST_DELETED
  SYSTEM_NOTICE
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

enum ReportReason {
  SPAM
  HARASSMENT
  INAPPROPRIATE_CONTENT
  PLAGIARISM
  OTHER
}

enum EntryType {
  MOMENT
  ARTICLE
}

enum EntryVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum EntryStatus {
  DRAFT
  PUBLISHED
}

// ─── Models ────────────────────────────────────────────

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  email        String     @unique
  passwordHash String
  role         UserRole   @default(USER)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  profile       UserProfile?
  posts         Post[]
  entries       Entry[]
  entryLikes    EntryLike[]
  comments      Comment[]
  commentLikes  CommentLike[]
  corrections   Correction[]
  reputationLog ReputationLog[]
  collections   ExpressionCollectionItem[]
  notifications Notification[]
  reports         Report[]         @relation("Reporter")
  resolvedReports Report[]         @relation("Resolver")
  adminActions    AdminActionLog[]

  @@index([status])
  @@index([role])
}

model UserProfile {
  id                 String           @id @default(cuid())
  userId             String           @unique
  displayName        String?
  bio                String?
  avatarUrl          String?
  nativeLanguageId   String?
  learningLanguageId String?
  level              ProficiencyLevel @default(BEGINNER)
  reputationScore    Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nativeLanguage   Language? @relation("NativeLanguage", fields: [nativeLanguageId], references: [id], onDelete: SetNull)
  learningLanguage Language? @relation("LearningLanguage", fields: [learningLanguageId], references: [id], onDelete: SetNull)
}

model Language {
  id         String @id @default(cuid())
  code       String @unique
  name       String
  nativeName String
  createdAt  DateTime @default(now())

  nativeProfiles   UserProfile[] @relation("NativeLanguage")
  learningProfiles UserProfile[] @relation("LearningLanguage")
  sourcePosts      Post[]        @relation("SourceLanguage")
  targetPosts      Post[]        @relation("TargetLanguage")
  sourceEntries    Entry[]       @relation("EntrySourceLanguage")
  targetEntries    Entry[]       @relation("EntryTargetLanguage")
}

model Post {
  id               String         @id @default(cuid())
  authorId         String
  sourceLanguageId String?
  targetLanguageId String?
  title            String?
  content          String
  expressionType   String?
  tone             String?
  visibility       PostVisibility   @default(PUBLIC)
  completeness     PostCompleteness @default(COMPLETE)
  status           PostStatus       @default(PUBLISHED)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  author         User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  sourceLanguage Language? @relation("SourceLanguage", fields: [sourceLanguageId], references: [id], onDelete: SetNull)
  targetLanguage Language? @relation("TargetLanguage", fields: [targetLanguageId], references: [id], onDelete: SetNull)

  corrections  Correction[]
  collections  ExpressionCollectionItem[]
  reports      Report[]

  @@index([authorId])
  @@index([status, visibility])
  @@index([createdAt])
}

model Entry {
  id               String         @id @default(cuid())
  authorId         String
  type             EntryType      @default(MOMENT)
  title            String?
  content          String
  coverImage       String?
  sourceLanguageId String?
  targetLanguageId String?
  expressionType   String?
  tone             String?
  completeness     String?
  visibility       EntryVisibility @default(PUBLIC)
  status           EntryStatus     @default(PUBLISHED)
  tags             Json            @default("[]")
  isPinned         Boolean         @default(false)
  viewCount        Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  publishedAt      DateTime?

  author         User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  sourceLanguage Language? @relation("EntrySourceLanguage", fields: [sourceLanguageId], references: [id], onDelete: SetNull)
  targetLanguage Language? @relation("EntryTargetLanguage", fields: [targetLanguageId], references: [id], onDelete: SetNull)
  likes          EntryLike[]
  comments       Comment[]

  @@index([authorId])
  @@index([type, status, visibility])
  @@index([createdAt])
}

model Correction {
  id            String           @id @default(cuid())
  postId        String
  authorId      String
  correctedText String
  explanation   String?
  toneNote      String?
  status        CorrectionStatus @default(PUBLISHED)
  isAccepted    Boolean          @default(false)
  acceptedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  post      Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  segments    CorrectionSegment[]
  collections ExpressionCollectionItem[]
  reports     Report[]
  comments    Comment[]

  @@index([postId])
  @@index([authorId])
  @@index([isAccepted])
  @@index([acceptedAt])
  @@index([createdAt])
}

model CorrectionSegment {
  id            String @id @default(cuid())
  correctionId  String
  position      Int
  originalText  String
  correctedText String
  explanation   String?

  correction Correction @relation(fields: [correctionId], references: [id], onDelete: Cascade)

  @@index([correctionId])
}

model ReputationLog {
  id         String   @id @default(cuid())
  userId     String
  points     Int
  reason     String
  sourceType String
  sourceId   String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model ExpressionCollectionItem {
  id                     String   @id @default(cuid())
  userId                 String
  postId                 String
  correctionId           String?
  originalTextSnapshot   String
  correctedTextSnapshot  String?
  explanationSnapshot    String?
  toneNoteSnapshot       String?
  tags                   Json     @default("[]")
  lastReviewedAt         DateTime?
  reviewStatus           String?
  reviewCount            Int      @default(0)
  createdAt              DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  post       Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  correction Correction? @relation(fields: [correctionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([postId])
  @@unique([userId, postId, correctionId])
}

model Notification {
  id                   String           @id @default(cuid())
  userId               String
  type                 NotificationType
  title                String
  body                 String?
  isRead               Boolean          @default(false)
  relatedPostId        String?
  relatedCorrectionId  String?
  createdAt            DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model Report {
  id            String       @id @default(cuid())
  reporterId    String
  postId        String?
  correctionId  String?
  reason        ReportReason
  description   String?
  status        ReportStatus @default(PENDING)
  resolvedById  String?
  resolvedAt    DateTime?
  createdAt     DateTime     @default(now())

  reporter   User         @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  post       Post?        @relation(fields: [postId], references: [id], onDelete: SetNull)
  correction Correction?  @relation(fields: [correctionId], references: [id], onDelete: SetNull)
  resolvedBy User?        @relation("Resolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([reporterId])
  @@index([status])
  @@index([postId])
  @@index([correctionId])
}

model AdminActionLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String?
  details    String?
  createdAt  DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model EntryLike {
  id        String   @id @default(cuid())
  entryId   String
  userId    String
  createdAt DateTime @default(now())

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entryId, userId])
  @@index([entryId])
}

model Comment {
  id           String    @id @default(cuid())
  entryId      String
  correctionId String?
  authorId     String
  parentId  String?
  body      String
  likeCount Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  entry    Entry      @relation(fields: [entryId], references: [id], onDelete: Cascade)
  correction Correction? @relation(fields: [correctionId], references: [id], onDelete: SetNull)
  author   User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  children Comment[] @relation("CommentReplies")
  likes    CommentLike[]

  @@index([entryId])
  @@index([authorId])
  @@index([parentId])
}

model CommentLike {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
}
