{
  "$schema": "https://opencode.ai/config.json",

  "lsp": true,

  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },

  "permission": {
    "edit": "ask",
    "bash": "ask"
  },

  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "serena",
        "start-mcp-server",
        "--context",
        "ide",
        "--project-from-cwd"
      ],
      "enabled": true,
      "timeout": 20000
    }
  }
}